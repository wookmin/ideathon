PORT=4000
NODE_ENV=development

# Comma-separated list. Example:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=

# One of: sandbox, development, production
CODEF_ENV=sandbox
CODEF_CLIENT_ID=your_codef_client_id
CODEF_CLIENT_SECRET=your_codef_client_secret

# Use a long random string in production.
APP_ENCRYPTION_SECRET=replace-with-a-long-random-string
